---
import Layout from '~/layouts/Layout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Velloc Agent — One agent. Many hands.',
  description:
    'Velloc Agent is a general AI agent on your desktop. It ships code, works the web like you do, and remembers. Your keys, your machine.',
  ignoreTitleTemplate: true,
};

const downloadUrl = SITE?.download || 'https://velloc.app/download/install.exe';
---

<Layout metadata={metadata}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700;12..96,800&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <div class="va-root">
    <header class="va-header">
      <a class="va-wordmark" href="/">Velloc<span>Agent</span></a>
      <nav class="va-nav">
        <a href="/index-browser">Velloc Browser</a>
        <a class="va-btn va-btn-small" href={downloadUrl}>Download</a>
      </nav>
    </header>

    <main class="va-main">
      <p class="va-eyebrow">General agent · runs on your desktop</p>
      <h1 class="va-h1">One agent.<br />Many <span class="va-grad">hands</span>.</h1>
      <p class="va-sub">
        It <span class="va-c-fs">writes code</span> and <span class="va-c-browser">works the web</span> like you do —
        then runs your shell, keeps your files, and remembers. All on your machine.
      </p>
      <a class="va-btn va-btn-primary" href={downloadUrl}>
        Download for Windows
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v12m0 0l-5-5m5 5l5-5M5 20h14"/></svg>
      </a>
      <p class="va-note">Free · Windows 10/11 · ships inside Velloc Browser</p>

      <!-- the one reactive thing -->
      <div class="va-demo">
        <div class="va-chips" role="group" aria-label="Try a task">
          <button class="va-chip is-active" data-s="0">fix a test</button>
          <button class="va-chip" data-s="1">shop the web</button>
          <button class="va-chip" data-s="2">morning routine</button>
          <button class="va-chip" data-s="3">use a skill</button>
        </div>
        <div class="va-card" id="vaCard">
          <div class="va-prompt"><span class="va-caret-label">›</span><span id="vaPrompt"></span><span class="va-caret"></span></div>
          <div class="va-lines" id="vaLines"></div>
        </div>
      </div>

      <p class="va-hands-line">
        <span class="va-c-fs">fs.*</span> edits your code ·
        <span class="va-c-shell">shell.*</span> runs your commands ·
        <span class="va-c-browser">browser.*</span> drives a real browser ·
        <span class="va-c-mem">memory</span> carries over
      </p>
      <p class="va-keys-line">
        Teach it new tricks: skills and plugins from the Anthropic plugin marketplace, or any MCP server.
      </p>
      <p class="va-keys-line">
        Bring your own keys — Anthropic, OpenAI, Google, or local via Ollama. Nothing leaves your machine.
      </p>
    </main>

    <footer class="va-footer">
      <span>© 2026 Velloc contributors</span>
      <span>
        <a href="https://github.com/browser-lab/browser-lab-bootstrap" target="_blank" rel="noopener">GitHub</a>
        <a href="/index-browser">Velloc Browser</a>
      </span>
    </footer>
  </div>
</Layout>

<style is:global>
  .va-root {
    --bg: #0b0e17;
    --line: #222a3d;
    --ink: #f2f1ec;
    --muted: #9ba3b5;
    --browser: #6c8cff;
    --fs: #ffb454;
    --shell: #3ddc97;
    --mem: #c09bff;
    --display: 'Bricolage Grotesque', sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    color: var(--ink);
    font-family: system-ui, sans-serif;
    letter-spacing: normal;
  }
  .va-c-browser { color: var(--browser); font-weight: 600; }
  .va-c-fs { color: var(--fs); font-weight: 600; }
  .va-c-shell { color: var(--shell); font-weight: 600; }
  .va-c-mem { color: var(--mem); font-weight: 600; }

  .va-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 46rem;
    width: 100%;
    margin: 0 auto;
    padding: 1.1rem 1.25rem;
  }
  .va-wordmark { font-family: var(--display); font-weight: 800; font-size: 1.1rem; color: var(--ink); }
  .va-wordmark span { color: var(--browser); font-weight: 700; margin-left: 0.25rem; }
  .va-nav { display: flex; align-items: center; gap: 1.2rem; }
  .va-nav > a:first-child { font-size: 0.85rem; color: var(--muted); }
  .va-nav > a:first-child:hover { color: var(--ink); }

  .va-main {
    flex: 1;
    max-width: 46rem;
    width: 100%;
    margin: 0 auto;
    padding: 3.5rem 1.25rem 3rem;
    text-align: center;
  }
  .va-eyebrow {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--shell);
    margin-bottom: 1rem;
  }
  .va-h1 {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(2.8rem, 8vw, 4.8rem);
    line-height: 1.0;
    letter-spacing: -0.025em;
    margin: 0 0 1.2rem;
  }
  .va-grad {
    background: linear-gradient(90deg, var(--fs), var(--browser), var(--shell), var(--mem));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .va-sub {
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 32rem;
    margin: 0 auto 1.8rem;
  }
  .va-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--display);
    font-weight: 700;
    border-radius: 0.8rem;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .va-btn:hover { transform: translateY(-1px); }
  .va-btn:focus-visible { outline: 3px solid var(--browser); outline-offset: 3px; }
  .va-btn-primary {
    background: var(--browser);
    color: #0b0e17;
    font-size: 1.02rem;
    padding: 0.9rem 1.6rem;
    box-shadow: 0 10px 30px -10px color-mix(in srgb, var(--browser) 65%, transparent);
  }
  .va-btn-primary:hover { background: #83a0ff; }
  .va-btn-primary svg { width: 1.1rem; height: 1.1rem; }
  .va-btn-small { background: var(--browser); color: #0b0e17; font-size: 0.82rem; padding: 0.45rem 0.95rem; border-radius: 0.6rem; }
  .va-note { font-family: var(--mono); font-size: 0.72rem; color: var(--muted); margin-top: 0.9rem; }

  /* demo card */
  .va-demo { margin: 2.8rem auto 0; max-width: 34rem; text-align: left; }
  .va-chips { display: flex; justify-content: center; gap: 0.5rem; margin-bottom: 0.8rem; flex-wrap: wrap; }
  .va-chip {
    font-family: var(--mono);
    font-size: 0.76rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }
  .va-chip:hover { border-color: var(--browser); color: var(--ink); }
  .va-chip:focus-visible { outline: 2px solid var(--browser); outline-offset: 2px; }
  .va-chip.is-active { background: var(--browser); border-color: var(--browser); color: #0b0e17; }

  .va-card {
    border: 1px solid var(--line);
    border-radius: 0.9rem;
    background: #0d1120;
    padding: 1.1rem 1.2rem;
    min-height: 13.5rem;
    box-shadow: 0 24px 60px -28px rgb(0 0 0 / 0.7);
  }
  .va-prompt {
    font-family: var(--mono);
    font-size: 0.84rem;
    color: var(--ink);
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0.9rem;
    min-height: 2.2rem;
  }
  .va-caret-label { color: var(--browser); margin-right: 0.5rem; font-weight: 600; }
  .va-caret {
    display: inline-block;
    width: 0.55em;
    height: 1.1em;
    margin-left: 2px;
    background: var(--browser);
    vertical-align: text-bottom;
    animation: va-blink 1s steps(1) infinite;
  }
  @keyframes va-blink { 50% { opacity: 0; } }

  .va-lines { display: flex; flex-direction: column; gap: 0.5rem; }
  .va-line {
    font-family: var(--mono);
    font-size: 0.76rem;
    color: var(--muted);
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .va-line.is-in { opacity: 1; transform: none; }
  .va-line .m { color: var(--fs); }
  .va-line.is-done .m { color: var(--shell); }
  .va-line .t { color: var(--ns); }
  .va-line .a { opacity: 0.65; }
  .va-reply {
    font-size: 0.86rem;
    font-family: system-ui, sans-serif;
    line-height: 1.6;
    color: var(--ink);
    background: rgb(255 255 255 / 0.05);
    border: 1px solid rgb(255 255 255 / 0.09);
    border-radius: 0.6rem;
    padding: 0.6rem 0.8rem;
    margin-top: 0.4rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .va-reply.is-in { opacity: 1; transform: none; }
  .va-reply em { font-style: normal; color: var(--shell); font-weight: 600; }

  .va-hands-line {
    font-family: var(--mono);
    font-size: 0.76rem;
    color: var(--muted);
    margin-top: 2.6rem;
    line-height: 2;
  }
  .va-keys-line { font-size: 0.86rem; color: var(--muted); margin-top: 0.7rem; }

  .va-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    max-width: 46rem;
    width: 100%;
    margin: 0 auto;
    padding: 1.2rem 1.25rem;
    border-top: 1px solid var(--line);
    font-size: 0.78rem;
    color: var(--muted);
  }
  .va-footer a { margin-left: 1rem; }
  .va-footer a:first-child { margin-left: 0; }
  .va-footer a:hover { color: var(--ink); }

  @media (prefers-reduced-motion: reduce) {
    .va-line, .va-reply, .va-btn { transition: none !important; }
    .va-caret { animation: none; }
  }
</style>

<script>
  interface Scenario {
    prompt: string;
    tools: { name: string; ns: string; arg?: string }[];
    reply: string;
  }

  const scenarios: Scenario[] = [
    {
      prompt: 'Tests are red on main. Find it and fix it.',
      tools: [
        { name: 'shell.run', ns: 'shell', arg: 'npm test' },
        { name: 'fs.edit', ns: 'fs', arg: 'src/utils/format.ts' },
        { name: 'shell.run', ns: 'shell', arg: 'npm test' },
      ],
      reply: 'formatPrice was truncating instead of rounding. One-line fix — <em>12/12 passing</em>.',
    },
    {
      prompt: 'Find the cheapest RTX 4070 that ships this week.',
      tools: [
        { name: 'browser.navigate', ns: 'browser', arg: 'gpudeals.example' },
        { name: 'browser.read_page', ns: 'browser' },
        { name: 'fs.write', ns: 'fs', arg: 'shopping.md' },
      ],
      reply: 'TurboCore at <em>$529</em>, ships today. Comparison saved to shopping.md.',
    },
    {
      prompt: 'Every morning: pull main, run tests, leave me a report.',
      tools: [
        { name: 'shell.run', ns: 'shell', arg: 'git pull && npm test' },
        { name: 'fs.write', ns: 'fs', arg: 'reports/morning.md' },
        { name: 'schedule.create', ns: 'mem', arg: 'daily 07:00' },
      ],
      reply: 'All green today. From tomorrow the report is ready at <em>7:00</em> — read it with coffee.',
    },
    {
      prompt: 'Turn meeting-notes.md into a slide deck.',
      tools: [
        { name: 'skill.load', ns: 'mem', arg: 'pptx' },
        { name: 'fs.read', ns: 'fs', arg: 'meeting-notes.md' },
        { name: 'fs.write', ns: 'fs', arg: 'deck.pptx' },
      ],
      reply: 'Ten slides in <em>deck.pptx</em> — built with the pptx skill from the plugin marketplace.',
    },
  ];

  function init() {
    const promptEl = document.getElementById('vaPrompt');
    const linesEl = document.getElementById('vaLines');
    const card = document.getElementById('vaCard');
    const chips = document.querySelectorAll<HTMLButtonElement>('.va-chip');
    if (!promptEl || !linesEl || !card || card.dataset.init) return;
    card.dataset.init = '1';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, reduced ? 0 : ms));
    let token = 0;
    let cycleTimer: ReturnType<typeof setTimeout> | undefined;

    async function play(i: number) {
      const s = scenarios[i];
      const t = ++token;
      clearTimeout(cycleTimer);
      chips.forEach((c) => c.classList.toggle('is-active', Number(c.dataset.s) === i));
      promptEl!.textContent = '';
      linesEl!.innerHTML = '';
      await sleep(400);

      // type the prompt
      for (let n = 1; n <= s.prompt.length; n++) {
        if (t !== token) return;
        promptEl!.textContent = s.prompt.slice(0, n);
        await sleep(26);
      }
      if (reduced) promptEl!.textContent = s.prompt;
      await sleep(450);

      // tool calls
      for (const tool of s.tools) {
        if (t !== token) return;
        const el = document.createElement('div');
        el.className = 'va-line';
        el.style.setProperty('--ns', `var(--${tool.ns === 'mem' ? 'mem' : tool.ns})`);
        el.innerHTML = `<span class="m">▸</span><span class="t">${tool.name}</span>${tool.arg ? `<span class="a">${tool.arg}</span>` : ''}`;
        linesEl!.appendChild(el);
        requestAnimationFrame(() => el.classList.add('is-in'));
        await sleep(850);
        if (t !== token) return;
        el.classList.add('is-done');
        el.querySelector('.m')!.textContent = '✓';
        await sleep(250);
      }

      // reply
      if (t !== token) return;
      const reply = document.createElement('div');
      reply.className = 'va-reply';
      reply.innerHTML = s.reply;
      linesEl!.appendChild(reply);
      requestAnimationFrame(() => reply.classList.add('is-in'));

      // idle-cycle to the next scenario
      cycleTimer = setTimeout(() => {
        if (t === token) play((i + 1) % scenarios.length);
      }, reduced ? 6000 : 4500);
    }

    chips.forEach((chip) => chip.addEventListener('click', () => play(Number(chip.dataset.s))));
    play(0);
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
